<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Estilo para las tarjetas -->
    <style name="CardStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/cardBackground</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:backgroundTint">@color/cardBackground</item>
    </style>

    <style name="NotifDialogTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.4</item>
    </style>

    <style name="NotifAnim" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/slide_down</item>
        <item name="android:windowExitAnimation">@anim/slide_up</item>
    </style>

    <style name="CalendarHeader">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/barlow_bold</item>
    </style>
    <style name="CalendarWeekDay">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/barlow</item>
    </style>
    <style name="CalendarDate">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/barlow</item>
    </style>

    <style name="NoActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
    </style>

</resources>