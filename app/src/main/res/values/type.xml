<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Display Styles (Headers) -->
    <style name="TextDisplay">
        <item name="fontFamily">@font/bebas_neue</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextDisplay.Large">
        <item name="android:textSize">34sp</item> <!-- Reduced from 48sp -->
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextDisplay.Medium">
        <item name="android:textSize">24sp</item> <!-- Reduced from 32sp -->
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextDisplay.Small">
        <item name="android:textSize">18sp</item> <!-- Reduced from 22sp -->
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Body Styles (Content) -->
    <style name="TextBody">
        <item name="fontFamily">@font/barlow</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="TextBody.Large">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>
    <style name="TextBody.Small">
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Label Style (Accents/Subtitles) -->
    <style name="TextLabel">
        <item name="fontFamily">@font/barlow_bold</item>
        <item name="android:textSize">10sp</item> <!-- Reduced from 11sp -->
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/green</item>
    </style>
</resources>
