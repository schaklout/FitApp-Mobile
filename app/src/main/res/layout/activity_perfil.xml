<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PerfilActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/perfilScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding_h"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/header_padding_v">

                <TextView
                    android:id="@+id/saludoText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MI PERFIL"
                    style="@style/TextDisplay.Large"
                    android:textColor="@color/green" />

                <TextView
                    android:id="@+id/subText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONFIGURACIÓN Y LOGROS"
                    style="@style/TextLabel"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- Profile Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_card_medium"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                android:layout_marginBottom="@dimen/gap_section">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding_internal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/profile_image"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_user"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/CircleImageView"
                            app:strokeColor="@color/green"
                            app:strokeWidth="2dp"
                            android:padding="2dp" />

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/usernameText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="USUARIO"
                                style="@style/TextDisplay.Medium"
                                android:textColor="@color/white" />

                            <TextView
                                android:id="@+id/miembroDesdeText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MIEMBRO DESDE 2025"
                                style="@style/TextBody.Small"
                                android:textColor="@color/text_muted" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/nivelText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="INTERMEDIO"
                                style="@style/Widget.MaterialComponents.Chip.Action"
                                app:chipBackgroundColor="@color/green_dim"
                                android:textColor="@color/green"
                                android:layout_marginTop="4dp"
                                app:chipCornerRadius="@dimen/radius_small"
                                app:chipStrokeWidth="0dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/btnEditProfile"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_edit"
                            app:tint="@color/green"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border_subtle"
                        android:layout_marginVertical="20dp" />

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/pesoText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextDisplay.Medium"
                                android:textColor="@color/green" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PESO (KG)"
                                style="@style/TextLabel"
                                android:textColor="@color/text_muted" />
                        </LinearLayout>

                        <LinearLayout
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/alturaText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextDisplay.Medium"
                                android:textColor="@color/green" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ALTURA (M)"
                                style="@style/TextLabel"
                                android:textColor="@color/text_muted" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stats Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESTADÍSTICAS"
                style="@style/TextLabel"
                android:layout_marginBottom="@dimen/gap_related" />

            <!-- Stats Grid -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Calories Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_card_small"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="@dimen/gap_related">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_fitness"
                            app:tint="@color/green"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CALORÍAS TOTALES"
                                style="@style/TextLabel"
                                android:textColor="@color/text_muted" />

                            <TextView
                                android:id="@+id/caloriasText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextDisplay.Small"
                                android:textColor="@color/white" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Active Days Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_card_small"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="@dimen/gap_related">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_calender"
                            app:tint="@color/green"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DÍAS ACTIVOS"
                                style="@style/TextLabel"
                                android:textColor="@color/text_muted" />

                            <TextView
                                android:id="@+id/diasActivosText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextDisplay.Small"
                                android:textColor="@color/white" />

                            <TextView
                                android:id="@+id/rachaText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RACHA: 0 DÍAS 🔥"
                                style="@style/TextBody.Small"
                                android:textColor="@color/green"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Routines Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_card_small"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="@dimen/gap_section">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_fitness"
                            app:tint="@color/green"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RUTINAS FINALIZADAS"
                                style="@style/TextLabel"
                                android:textColor="@color/text_muted" />

                            <TextView
                                android:id="@+id/rutinasFinalizadasText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextDisplay.Small"
                                android:textColor="@color/white" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="CERRAR SESIÓN"
                android:textColor="@color/white"
                
                android:textStyle="bold"
                android:letterSpacing="0.12"
                app:backgroundTint="@color/black"
                app:strokeColor="@color/red_accent"
                app:strokeWidth="1dp"
                app:cornerRadius="@dimen/radius_pill"
                android:layout_marginBottom="@dimen/gap_section"
                app:icon="@drawable/ic_logout"
                app:iconGravity="textStart"
                app:iconTint="@color/red_accent" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
