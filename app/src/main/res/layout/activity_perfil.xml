<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERFIL"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.04"
            android:paddingTop="8dp"
            android:paddingBottom="16dp" />

        <!-- Profile Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="0.5dp"
            android:layout_marginBottom="16dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/profile_image"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@drawable/ic_user"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleImageView"
                        app:strokeColor="@color/green"
                        app:strokeWidth="2.5dp"
                        android:padding="3dp" />

                    <TextView
                        android:id="@+id/saludoText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Usuario"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:fontFamily="@font/bebas_neue"
                        android:letterSpacing="0.02" />

                    <TextView
                        android:id="@+id/usernameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="email@email.com"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="@font/barlow" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/nivelText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INTERMEDIO"
                            android:textColor="@color/green"
                            android:textSize="10sp"
                            android:fontFamily="@font/barlow_bold"
                            android:letterSpacing="0.08"
                            android:background="@drawable/bg_level"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp" />

                        <TextView
                            android:id="@+id/miembroDesdeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Miembro desde 2025"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="@font/barlow" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_subtle"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp" />

                <!-- Body stats row -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/pesoText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/green"
                            android:textSize="26sp"
                            android:fontFamily="@font/bebas_neue" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PESO (KG)"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="@font/barlow_bold"
                            android:letterSpacing="0.06" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/border_subtle" />

                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/alturaText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/green"
                            android:textSize="26sp"
                            android:fontFamily="@font/bebas_neue" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALTURA (M)"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:fontFamily="@font/barlow_bold"
                            android:letterSpacing="0.06" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Edit button top-right -->
            <LinearLayout
                android:id="@+id/btnEditProfile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end|top"
                android:layout_margin="12dp"
                android:gravity="center"
                android:background="@drawable/bg_level"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/green"
                    android:scaleType="fitCenter" />
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

        <!-- Stats Grid 2x2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#3384F527"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CALORÍAS"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:fontFamily="@font/barlow_bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/caloriasText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="@color/green"
                        android:textSize="24sp"
                        android:fontFamily="@font/bebas_neue" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#3384F527"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RUTINAS"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:fontFamily="@font/barlow_bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/rutinasFinalizadasText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:fontFamily="@font/bebas_neue" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Second row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#3384F527"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DÍAS ACTIVOS"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:fontFamily="@font/barlow_bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/diasActivosText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:fontFamily="@font/bebas_neue" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#3384F527"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RACHA"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:fontFamily="@font/barlow_bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/rachaText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0 días"
                        android:textColor="@color/green"
                        android:textSize="24sp"
                        android:fontFamily="@font/bebas_neue" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Logout -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Cerrar sesión"
            android:textColor="@color/red_accent"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:textSize="13sp"
            android:fontFamily="@font/barlow_bold"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/red_accent"
            app:strokeWidth="1dp"
            app:cornerRadius="@dimen/radius_pill"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/red_accent"
            app:iconGravity="textStart" />

    </LinearLayout>
</ScrollView>
