<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/entrenoScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="32dp">

        <!-- Timer Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#3384F527"
            app:strokeWidth="1.5dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIEMPO"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:fontFamily="@font/barlow_bold"
                    android:letterSpacing="0.08" />

                <Chronometer
                    android:id="@+id/chronometer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/green"
                    android:textSize="40sp"
                    android:fontFamily="@font/bebas_neue" />

                <TextView
                    android:id="@+id/tvTituloEntrenamiento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Título de la Rutina"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/bebas_neue"
                    android:letterSpacing="0.02"
                    android:gravity="center" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Multimedia Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#3384F527"
            app:strokeWidth="1.5dp"
            android:layout_marginBottom="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp">

                <ImageView
                    android:id="@+id/ivImagenEntrenamiento"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <VideoView
                    android:id="@+id/videoRutina"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/progressLoader"
                    style="?android:attr/progressBarStyleLarge"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Metrics -->
        <TextView
            android:id="@+id/tvMetricasEntrenamiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/barlow"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvDescripcionEntrenamiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Descripción de la rutina"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/barlow"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3" />

        <!-- Ejercicios -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#3384F527"
            app:strokeWidth="1.5dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EJERCICIOS"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:fontFamily="@font/barlow_bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/linearEjercicios"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinalizarEntrenamiento"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Finalizar entrenamiento"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/barlow_bold"
            android:letterSpacing="0.04"
            android:textAllCaps="true"
            app:backgroundTint="@color/green"
            app:cornerRadius="@dimen/radius_pill"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalirEntrenamiento"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Salir"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/barlow_bold"
            android:letterSpacing="0.04"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:cornerRadius="@dimen/radius_pill" />

    </LinearLayout>
</ScrollView>
