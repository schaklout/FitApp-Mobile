<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".DashboardActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/screen_padding_h">

            <!-- Header Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/header_padding_v">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡HOLA!"
                    style="@style/TextDisplay.Large"
                    android:textColor="@color/green" />

                <TextView
                    android:id="@+id/tvSubGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LISTO PARA ENTRENAR"
                    style="@style/TextLabel"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- Motivation Quote -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_2"
                app:cardCornerRadius="@dimen/radius_card_small"
                app:cardElevation="0dp"
                android:layout_marginBottom="@dimen/gap_section">

                <TextView
                    android:id="@+id/tvMotivation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/card_padding_internal"
                    android:text="“La constancia vence al talento cuando el talento no es constante.”"
                    style="@style/TextBody"
                    android:gravity="center"
                    android:textStyle="italic" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Carousel Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESTACADO"
                style="@style/TextLabel"
                android:layout_marginBottom="@dimen/gap_related" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/imageCarousel"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="@dimen/gap_micro"
                android:clipToPadding="false"
                android:clipChildren="false" />

            <LinearLayout
                android:id="@+id/dotsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/gap_section" />

            <!-- Progress Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TU PROGRESO HOY"
                style="@style/TextLabel"
                android:layout_marginBottom="@dimen/gap_related" />

            <!-- Progress Cards Grid-like -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Row 1: Calories & Weight -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- Calories Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/gap_micro"
                        android:layout_marginBottom="@dimen/gap_related"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="@dimen/radius_card_medium"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/border"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/card_padding_internal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CALORÍAS"
                                style="@style/TextLabel"
                                android:textColor="@color/text_muted" />

                            <TextView
                                android:id="@+id/tvCalorias"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextDisplay.Medium"
                                android:textColor="@color/green" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Weight Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/gap_micro"
                        android:layout_marginBottom="@dimen/gap_related"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="@dimen/radius_card_medium"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/border"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/card_padding_internal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PESO"
                                style="@style/TextLabel"
                                android:textColor="@color/text_muted" />

                            <TextView
                                android:id="@+id/tvPesoActual"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kg"
                                style="@style/TextDisplay.Medium"
                                android:textColor="@color/green" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 2: IMC & Routines -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- IMC Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/gap_micro"
                        android:layout_marginBottom="@dimen/gap_section"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="@dimen/radius_card_medium"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/border"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/card_padding_internal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="IMC"
                                style="@style/TextLabel"
                                android:textColor="@color/text_muted" />

                            <TextView
                                android:id="@+id/tvImc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextDisplay.Medium"
                                android:textColor="@color/green" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Routines Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/gap_micro"
                        android:layout_marginBottom="@dimen/gap_section"
                        app:cardBackgroundColor="@color/surface"
                        app:cardCornerRadius="@dimen/radius_card_medium"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/border"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/card_padding_internal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RUTINAS"
                                style="@style/TextLabel"
                                android:textColor="@color/text_muted" />

                            <TextView
                                android:id="@+id/tvRutinas"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                style="@style/TextDisplay.Medium"
                                android:textColor="@color/green" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/surface"
        app:itemIconTint="@color/nav_icon_color"
        app:itemTextColor="@color/nav_icon_color"
        
        app:itemPaddingTop="10dp"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"/>

</LinearLayout>
