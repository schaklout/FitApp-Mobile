<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".RutinasActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/rutinasScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/screen_padding_h">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="@dimen/header_padding_v">

                <TextView
                    android:id="@+id/tvTituloRutinas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TUS RUTINAS"
                    style="@style/TextDisplay.Large"
                    android:textColor="@color/green" />

                <TextView
                    android:id="@+id/tvSubtituloRutinas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENTRENAMIENTOS DE HOY"
                    style="@style/TextLabel"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- Calendar Action -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalendario"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="VER CALENDARIO"
                android:textColor="@color/black"
                
                android:textStyle="bold"
                android:letterSpacing="0.12"
                app:backgroundTint="@color/green"
                app:cornerRadius="@dimen/radius_pill"
                android:layout_marginBottom="@dimen/gap_section" />

            <!-- Routines List Container -->
            <LinearLayout
                android:id="@+id/linearRutinasActivas"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Empty State -->
            <TextView
                android:id="@+id/tvNoRutinasActivas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NO HAY RUTINAS PARA HOY."
                style="@style/TextBody"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginVertical="@dimen/gap_section" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
