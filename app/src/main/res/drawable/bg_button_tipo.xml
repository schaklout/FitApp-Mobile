<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Estado presionado -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#33FF5722" /> <!-- color naranja semi-transparente al presionar -->
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Estado normal -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF5722"/> <!-- color de fondo principal -->
            <corners android:radius="24dp"/>
        </shape>
    </item>

</selector>
